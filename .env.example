# .env.example — Copy this to .env and fill in your values
# NEVER commit .env to git.
#
# ──────────────────────────────────────────────────────────────────────
# Instructions for each variable are provided inline.
# See docs/setup-local.md for the full walkthrough.
# ──────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Session ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-64-char-string

# ── Google OAuth 2.0 ─────────────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URIs:
#    http://localhost:8080/auth/callback  (local dev)
#    https://YOUR_CLOUD_RUN_URL/auth/callback  (production)
# 4. Enable "Photos Library API" in the GCP console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/callback

# ── Google Gemini API ────────────────────────────────────────────────
# 1. Go to: https://aistudio.google.com/app/apikey
# 2. Create API key
# 3. Paste it below
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ── Google Cloud Project ─────────────────────────────────────────────
# Required for Firestore, Cloud Logging, and Cloud Storage
# 1. Go to: https://console.cloud.google.com/
# 2. Create or select a project
# 3. Copy the Project ID (not Project Name)
GCP_PROJECT_ID=your-gcp-project-id

# ── Google Application Credentials (local dev only) ──────────────────
# For local development, download a service account JSON key and set this path.
# In production (Cloud Run), the default compute service account is used instead.
# 1. IAM → Service Accounts → Create → Add roles: Firestore User, Storage Admin, Logging Writer
# 2. Keys → Add Key → JSON
# 3. Set this path to the downloaded JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# ── Google Cloud Storage ─────────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com/storage/browser
# 2. Create a bucket (e.g. "memory-weaver-audio")
# 3. Set CORS and make-public settings (see docs/setup-local.md)
GCS_BUCKET_NAME=your-gcs-bucket-name

# ── Frontend URL ─────────────────────────────────────────────────────
# URL of the React SPA — used for CORS allow-list and OAuth redirects.
# Local dev: http://localhost:5173
# Production: https://YOUR_CLOUD_RUN_URL
FRONTEND_URL=http://localhost:5173

# ── Cloud Logging ─────────────────────────────────────────────────────
CLOUD_LOG_NAME=memory-weaver

# ── Frontend environment variables ───────────────────────────────────
# These are read by Vite (prefix VITE_ is required).
# Create a separate client/.env.local with these:
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
