# client/.env.local — Vite environment variables for the React SPA
# Copy this to client/.env.local and fill in your values.
# These are injected at build time by Vite (prefix VITE_ is required).

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com → Admin → Property → Data Streams
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
